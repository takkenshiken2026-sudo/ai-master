 automatically receive 200 credits \\n3. Validity: The 200 credits are valid for 5 days after being issued.\\nStart creating with the new version now!\",\"default_free_criedis_cn1\":\"创作焕新升级，免费领积分🎉🎉\",\"default_free_criedis_cn2\":\"1. 活动时间：即日起至3月17日24点前，所有用户均可参与\\n2. 领取方式：只需要登录账号，即可自动领取200 积分\\n3. 有效期：200 积分在发放后有效期 5 天，未使用的积分将在 5 天后过期\\n立即体验新版本创作吧\",\"default_project_cannot_delete\":\"默认项目无法删除\",\"defeate_btn_create_now\":\"立即体验\",\"delete_acc_popup_account\":\"输入您的手机号账号\",\"delete_acc_popup_btn\":\"注销账号\",\"delete_acc_popup_confirm_btn\":\"确认注销账号\",\"delete_acc_popup_content\":\"⚠️ 注销账户前,请您仔细阅读以下重要提示: \\\\n\\\\n1. 账户注销后将无法恢复\\\\n2. 您在海螺AI平台上的所有内容(包括视频和个人资料)将被永久删除,且无法找回\\\\n3. 账户中剩余的积分将全部清零\\\\n4.注销前您需手动终止后续订阅，已付的订阅费用无法退还\\\\n5. 重新注册时不再享受新用户福利\\\\n\\\\n请慎重考虑您的需求。一旦确认注销,操作将无法撤销。\",\"delete_acc_popup_info\":\"点击按钮后立即生效，不可撤销\",\"delete_acc_popup_title\":\"注销账号\",\"delete_acc_popup_verify\":\"如确认注销，请在下方输入您的账号：\",\"delete_audio_window_subtitle\":\"您确定要删除这个音频嘛？删除后将无法找回该音频。\",\"delete_audio_window_title\":\"删除音频\",\"delete_character_window_subtitle\":\"您确认要删除这个角色嘛？删除后将无法找回该角色。\",\"delete_character_window_title\":\"删除该角色\",\"delete_comfirm_popup_one\":\"删除选中的对话\",\"delete_comfirm_popup_other\":\"删除选中的对话\",\"delete_image_window_subtitle\":\"您确定要删除这张图片嘛？删除后将无法找回该图片。\",\"delete_image_window_title\":\"删除图片\",\"delete_my_account\":\"注销账号\",\"delete_popup\":\"删除\",\"delete_project_tips1\":\"此项目处于未付款状态，目前无法删除\",\"delete_project_tips2\":\"此项目正在进行中，目前无法删除\",\"delete_project_tips_desc\":\"您确定要删除该项目吗？删除后无法恢复。\",\"delete_project_tips_title\":\"确认删除\",\"delete_selected_conversation_confirmation_one\":\"确定要删除选中的对话吗？ 删除后无法恢复\",\"delete_selected_conversation_confirmation_other\":\"确定要删除选中的对话吗？ 删除后无法恢复\",\"delete_selected_folders\":\"删除指定文件夹？\",\"delete_selected_videos\":\"删除指定内容？\",\"delete_success_toast\":\"账号注销中...\",\"delete_video_window_subtitle\":\"您确定要删除这个视频嘛？删除后将无法找回该视频。\",\"delete_video_window_title\":\"删除视频\",\"deleted_voice_invalid_toast\":\"已失效的音色\",\"describe_image_content_prompt\":\"描述您想生成的图片，例如，“夕阳映照在海面上，鲜艳的色彩与汹涌的波涛交相辉映。”\",\"describe_video_content_prompt\":\"描述您想要生成的视频内容，例如，“一个孩子在公园里放风筝，金色阳光，镜头上移。”\",\"detail_camera_motion_prefix\":\"镜头运动：%s\",\"detail_page_prompt_detail\":\"展开\",\"detect_language_auto\":\"自动识别\",\"detect_language_default\":\"语言检测\",\"detect_language_hover\":\"支持手动设置正确的语种，以准确地生成音频\",\"detect_language_tip\":\"我们检测到您的文本语言为%n。\",\"detect_language_tip_confrim\":\"确认\",\"detect_language_tip_ingnore\":\"忽略\",\"detected_output\":\"自动检测\",\"dialog_answer_stopped\":\"回答已停止\",\"dialog_confirm_button\":\"知道了\",\"dialog_delete_preset_content\":\"你确定要删除当前预设吗？此操作无法撤销。\",\"dialog_delete_preset_title\":\"删除预设？\",\"dialog_feedback_better\":\"更好\",\"dialog_feedback_dissatisfied\":\"不满意\",\"dialog_feedback_same\":\"一样\",\"dialog_feedback_satisfied\":\"满意\",\"dialog_feedback_worse\":\"更差\",\"dialog_share_intelligent_agent\":\"分享智能体\",\"disable_hover_tooltip\":\"即将上线\",\"discount_biggest_ever\":\"史上最大折扣\",\"discount_biggest_ever_once_a_year\":\"史上最大折扣，全年仅此一次\",\"discount_code_apply\":\"应用\",\"discount_code_placeholder\":\"请输入优惠码\",\"discount_code_stacked_savings\":\"叠加优惠\",\"discount_code_title\":\"优惠码\",\"discount_code_tooltip\":\"优惠券折扣可与当前订阅方案的折扣叠加使用。\",\"disturbing_imagery\":\"令人不安的图像\",\"dont_miss_your_bonus_title\":\"新福利！加赠积分等你拿！\",\"double_press_exit\":\"再按一次退出应用\",\"downgrade_preview_lose_benefit_1\":\"10万声贝（约能生成2小时语音）\",\"downgrade_preview_lose_benefit_2\":\"更快的语音生成速度\",\"downgrade_preview_lose_benefit_3\":\"10个专属音色卡槽\",\"downgrade_preview_lose_benefit_4\":\"100万声贝（约能生成20小时语音）\",\"downgrade_preview_lose_benefit_5\":\"100个专属音色卡槽\",\"downgrade_preview_lose_benefit_6\":\"获得MiniMax Audio的商业使用许可\",\"downgrade_preview_lose_benefit_creator_0\":\"40万声贝（约能生成8小时音频），\u003cstrong\u003e不可累计至下月\u003c/strong\u003e\",\"downgrade_preview_lose_benefit_creator_1\":\"40个专属音色卡槽\",\"downgrade_preview_lose_benefit_creator_2\":\"MiniMax音频商用授权\",\"downgrade_preview_lose_benefit_pro_0\":\"400万声贝（约能生成80小时音频），\u003cstrong\u003e不可累计至下月\u003c/strong\u003e\",\"downgrade_preview_lose_benefit_pro_1\":\"500个专属音色卡槽\",\"downgrade_preview_lose_benefit_pro_2\":\"MiniMax音频商用授权\",\"download_agree_terms\":\"点击下载即同意《去水印规则》\",\"download_detail_i2v_content\":\"为静态图片注入生命力。让每一帧都充满故事感，创造出令人惊叹的视觉体验。\",\"download_detail_i2v_title\":\"\u003cgradient\u003e图\u003c/gradient\u003e生视频\",\"download_detail_s2v_content\":\"一张照片，无限可能。上传人物照片，让 AI 为你打造专属视频主角，创造独特的视觉故事。\",\"download_detail_s2v_title\":\"\u003cgradient\u003e主体\u003c/gradient\u003e参考\",\"download_detail_t2v_content\":\"告别复杂的视频制作流程。用文字描述你的创意，AI 就能将你的想象转化为精彩视频。就这么简单。\",\"download_detail_t2v_title\":\"\u003cgradient\u003e文\u003c/gradient\u003e生视频\",\"download_detail_title\":\"创意无界 随手成片\",\"download_detail_title_1\":\"创意\u003cgradient\u003e无界\u003c/gradient\u003e\",\"download_detail_title_2\":\"随手成片\",\"download_failed\":\"下载失败\",\"download_img\":\"下载原图\",\"download_modal_agreed_rules\":\"《去水印规则》\",\"download_page_QR\":\"扫码下载\",\"download_page_apple\":\"在App Store下载\",\"download_page_apple_store\":\"App Store\",\"download_page_content\":\"一句话描述你的想法，AI就能为你打造惊艳视频。从文字到视频，从静态到动态，海螺视频让创作变得前所未有的简单。无论是分享生活趣事，还是制作创意短片，你的想象力就是创作的极限。\",\"download_page_google\":\"在安卓下载\",\"download_page_google_store\":\"应用商店\",\"download_page_subtitle\":\"用AI重新定义视频创作\",\"download_page_title\":\"\u003cgradient\u003e海螺\u003c/gradient\u003eAI移动端App\",\"download_page_web\":\"网页版立即体验\",\"download_page_web_store\":\"海螺AI\",\"download_without_watermark_modal_btn\":\"同意并下载\",\"download_without_watermark_modal_tips\":\"您正在申请平台提供没有添加“AI生成”显著标识(下称“水印”）的内容。请您知悉并确认，您在平台内申请下载的包括但不限于本条无水印视频，仅可用于个人学习、收藏之用。如果您将视频用于发布、传播、公开等其他用途，您应当将视频用于合法合规的用途，并依法履行AI生成内容标识义务，根据实际使用场景对视频进行显著的标识和提示，说明其为AI生成内容，避免造成误导、混淆或误认，并独立承担相关后果和责任。\",\"download_without_watermark_modal_title\":\"特别提示\",\"downward_tilt\":\"降摇\",\"dropzone_desc\":\"支持包含人声的 MP3/WAV，最大50MB\",\"dropzone_title\":\"拖放上传\",\"earnings_credited\":\"已到账\",\"earnings_details\":\"收益明细\",\"edit_profile_confirm_save_edit\":\"是否保存当前编辑？\",\"edit_profile_discard_changes\":\"不保存\",\"edit_profile_edit_profile\":\"编辑资料\",\"edit_profile_enter_your_nickname\":\"请输入你的昵称\",\"edit_profile_name\":\"名字\",\"edit_profile_save\":\"保存\",\"editing_scene_crop\":\"裁剪\",\"editing_scene_inpaint\":\"涂抹\",\"editing_scene_rename\":\"重命名\",\"effective_date_tip\":\"您【%套餐名称%】续订费用已自动扣除\",\"effective_date_tip_2\":\"您的【%upgradeOrDowngrade%】操作将于【%effectDate%】生效\",\"effective_date_tip_3\":\"下期套餐如需调整，请在【%修改日期%】后提交修改申请，新套餐将于下次付费周期开始时生效。\",\"effective_date_tip_title\":\"生效日期提醒\",\"emotion_over_15_hover\":\"每次生成最多可以添加15种情绪\",\"emotion_selection_text\":\"升级以设置输出情绪\",\"empty_history_topic\":\"还没有话题历史\",\"empty_the_content\":\"清空\",\"emtion_over_90_toast\":\"添加情绪数量过多\",\"enable_notifications_popup_title\":\"开启通知\",\"end_frame_crop_tip\":\"首尾帧同时使用时，尾帧图会按照首帧的比例自动裁切\",\"end_frame_guide_desc\":\"首帧、尾帧、首尾帧，选择你需要的能力来生成视频吧！\",\"end_frame_guide_title\":\"图生视频支持上传尾帧图啦！\",\"end_frame_info_tip\":\"支持首帧、尾帧、首尾帧三种图生视频方式\",\"end_frame_tips\":\"仅尾帧\",\"end_frame_unsupported_with_model\":\"使用尾帧功能需要切换到\u003cenableModels\u003e\u003c/enableModels\u003e模型\",\"end_frame_unsupported_with_resolution\":\"512p不支持尾帧\",\"end_frame_upload_btn\":\"尾帧\",\"ends_in_duration\":\"结束于 %s\",\"enter_art_description_introduction\":\"输入描述，给别人介绍你的作品\",\"enter_name\":\"请输入文件夹名\",\"enter_template_edit_prompt\":\"请输入{itemName}的描述\",\"equity_compare_desc\":\"自动续费服务说明\\n1. 付款及续费：确认付款后，将从您的店铺账户中扣款。扣款日期为会员到期前一天，系统将通过应用商店自动为您续费。\\n2. 取消续费：您可以在扣款日期之前通过应用商店关闭续费服务并取消订阅。\\n3. 付款前注意事项：会员服务是虚拟产品，一旦付款，不提供退款。感谢您的理解。\",\"exclusive_offer_title\":\"🎉 专属邀请优惠！\",\"exit_create_modal_cancel_button\":\"取消\",\"exit_create_modal_confirm_button\":\"确定\",\"exit_create_modal_description\":\"退出后当前对话不保留，生成视频会在资产中展示，是否确认退出\",\"exit_create_modal_dont_remind\":\"不再提醒\",\"exit_create_modal_title\":\"退出当前任务\",\"expand_side_bar\":\"展开侧边栏\",\"expand_sidebar\":\"展开\",\"expand_toggle_button\":\"展开\",\"expiration_time_label\":\"到期时间\",\"face_portrait\":\"Face Portrait\",\"facecut_upload_sora\":\"不支持人脸\",\"facecut_upload_sora_toast\":\"你不能使用人脸作为输入图像。请尝试使用无版权的角色、产品或其他对象。\",\"faq_unlimtied_desc\":\"无限生成特权仅面对特定档位的会员提供，允许您在积分消耗完后可以继续在闲时模式无限次生成。比如MAX会员可以无限生成Hailuo 1.0和2.0系列模型，具体规则以活动页面显示规则为准。\\n在此模式下，您的任务请求将进入队列，其生成时间通常比快速生成模式更长。您可以随时使用积分生成，获得更快的生成速度。 \\n该功能仅限个人使用，严禁作弊、账号共享或转售行为。如检测到异常活动，访问权限可能会被临时暂停。\",\"faq_unlimtied_title\":\"无限生成特权说明\",\"fast_track_button\":\"立即充值\",\"fast_track_message\":\"充值贝壳以恢复快速生成\",\"favourites_only_choose\":\"仅收藏\",\"feature_coming_soon_desc\":\"音频功能即将推出，敬请期待！\",\"feature_coming_soon_title\":\"海螺音频\",\"feature_intro_subtitle_hailuo_agent\":\"无限画布，让创作更简单\",\"feature_intro_title_hailuo_agent\":\"Hailuo Agent\",\"feature_tip_frame_content\":\"上传尾帧图来控制视频的结束画面\",\"feature_tip_frame_title\":\"图生视频支持上传尾帧图啦！\",\"feed_end_tips\":\"到底了\",\"feed_refresh_tips\":\"下拉刷新\",\"feedback\":\"反馈\",\"feedback_input_placeholder\":\"请告诉我们您对答案不满意的原因。\\\\n您也可以提供一个更好的答案来帮助我们改进。\",\"feedback_modal_title\":\"反馈\",\"feedback_regen_ans\":\"重新生成的答案怎么样？\",\"feedback_submit\":\"提交\",\"file_preview_loading\":\"正在加载中...\",\"filter_generate_type\":\"按类型\",\"filter_time\":\"按日期\",\"filter_time_all\":\"所有时间\",\"filter_time_past_3_months\":\"过去三个月\",\"filter_time_past_month\":\"过去一个月\",\"filter_time_past_week\":\"过去一周\",\"filter_type_all\":\"全部\",\"filter_type_audio\":\"音频\",\"filter_type_image\":\"图片\",\"filter_type_video\":\"视频\",\"final_video_export_failed\":\"导出失败，请重试。\",\"final_video_export_select_nums\":\"选择导出集数\",\"final_video_export_settings\":\"导出设置\",\"final_video_export_text\":\"导出\",\"final_video_exporting\":\"导出中，请稍等...\",\"final_video_review_failed\":\"审核失败\",\"final_video_under_review\":\"审核中\",\"find_public_prompts_text\":\"在 \u003cofficialLibrary\u003e公共提示词\u003c/officialLibrary\u003e 中发现更多提示词 \u003cbr\u003e\u003c/br\u003e 或 \u003ccreateNewPreset\u003e创建新提示词\u003c/createNewPreset\u003e\",\"finished\":\"已完成\",\"first_frame\":\"首帧\",\"first_subscription_discount\":\"首次订阅享\",\"first_subscription_discount_2\":\"折优惠\",\"folder_deletion_tip\":\"* 文件夹里的内容仍在[全部作品]中\",\"folder_empty\":\"文件夹为空\",\"folder_pin_max_limit\":\"置顶文件夹数量已达到上限，请先移除再置顶新的文件夹\",