unks/2012-81ed5033affd2adb.js\",\"5477\",\"static/chunks/5477-890c46c17b567325.js\",\"585\",\"static/chunks/585-96b1fc58e605bfb0.js\",\"3619\",\"static/chunks/3619-b78ec0c3f3032b01.js\",\"1001\",\"static/chunks/1001-a2be3f1444c1dcd1.js\",\"6777\",\"static/chunks/6777-8c29bcd00fc44089.js\",\"2617\",\"static/chunks/2617-1ce56358cb5c3fb4.js\",\"2594\",\"static/chunks/2594-aa3c6ca670d72548.js\",\"1596\",\"static/chunks/1596-4e087d6b42128195.js\",\"6296\",\"static/chunks/6296-75b9777ef662631d.js\",\"265\",\"static/chunks/265-a8d6330dcd17947a.js\",\"9029\",\"static/chunks/9029-c51dbf8d5792ab1d.js\",\"3644\",\"static/chunks/3644-d603f1c90fd5b04a.js\",\"8749\",\"static/chunks/8749-cd06d8892aefa38b.js\",\"6597\",\"static/chunks/6597-cc28c1fe7627a250.js\",\"6653\",\"static/chunks/6653-d54c166b2a0dbc90.js\",\"5036\",\"static/chunks/5036-249038db27fcd5ed.js\",\"1000\",\"static/chunks/1000-7ba3379b9ee81535.js\",\"9674\",\"static/chunks/9674-cfc218e07a397044.js\",\"4044\",\"static/chunks/4044-245e9bf89036dcf0.js\",\"9893\",\"static/chunks/9893-83e3918cb41397be.js\",\"1664\",\"static/chunks/1664-4c6f8747b60973f9.js\",\"6357\",\"static/chunks/6357-2f29b14b77f9ee42.js\",\"2160\",\"static/chunks/2160-4c049d3f20f63347.js\",\"5803\",\"static/chunks/5803-9c8f73d010cd3dc2.js\",\"3578\",\"static/chunks/3578-2326552237037cce.js\",\"7426\",\"static/chunks/7426-8199688e99364b74.js\",\"6496\",\"static/chunks/6496-64b8a62fc2b1003e.js\",\"2846\",\"static/chunks/2846-c11cb0407829b99f.js\",\"6017\",\"static/chunks/app/%5Blocale%5D/(pages)/(home)/page-3ca7792c7679f010.js\"],\"default\"]\n"])</script><script>self.__next_f.push([1,"34:T15e7,"])</script><script>self.__next_f.push([1,"{\"intro\":\"欢迎您访问海螺AI，使用海螺AI产品和服务！ 我们在海螺AI中为您（“用户”）提供“主体参考”功能（“本功能”），协助您更好地使用海螺AI的内容生成服务（“服务”）。您可以在视频生成、图片生成等服务中使用相应的主体参考功能，在使用本功能之前，请您认真阅读并充分理解《主体参考功能使用须知》（“本须知”），您以点击确认等方式同意本须知以及《海螺AI用户协议》《海螺AI隐私政策》（统称“服务协议”）的，方可使用本功能。使用本功能过程中，请您持续关注并遵守本须知及各项服务协议的要求，让我们共同创造和维护良好的网络环境和产品生态。\",\"content\":[{\"title\":\"- 服务使用规则\",\"list\":[\"您理解、确认并承诺，您在使用海螺AI和本功能时输入、提交、上传、发布的各项内容（包括但不限于文字、图片、音频、视频等各种形式的内容及其中包含的文本、音乐、声音、图形图像、视觉设计、作品等所有组成部分，“输入内容”）均由您原创、拥有完整权利或已取得充分、合法、有效授权，输入内容的知识产权、所有权、人格权（包括但不限于肖像权等）、数据权益和/或其他相关权益由您和/或授权您的第三方依法享有，同时不侵犯任何人的知识产权、人格权、数据权益、商业秘密等合法权益，您应当就提供输入内容的行为独立承担责任。\",\"如您的输入内容包含自然人的人脸、肖像（统称“肖像”）的，您应当保证对该等信息享有充分的权利或您已取得权利人充分、合法、有效的授权。如您未就相关肖像取得必要授权，您不应在使用海螺AI或本功能时输入该等内容，否则，您应当独立承担由此导致的后果和责任。我们可能会对您输入内容中的肖像的特征点、矢量点进行检测和分析，以协助您使用服务，但我们不会将该等信息用于识别特定自然人。\",\"您使用海螺AI和本功能的，应当将服务、输入内容以及服务生成、输出的各项内容（“输出内容”）用于合法合规的用途，不应将其用于违法违规的用途，不得利用服务或输入内容、输出内容侵害他人合法权益，相关禁止行为和/或禁止的目的或用途（“禁止用途”）包括但不限于：（1）损害、丑化他人形象；（2）损害他人名誉；（3）冒用他人身份或名义；（4）贬低他人人格；（5）侮辱、诽谤、贬损、恶搞他人；（6）侵害未成年人合法权益或损害未成年人身心健康；（7）编造或传播谣言、虚假信息；（8）海螺AI各项服务协议中所禁止的行为；（9）其他违反法律法规或者侵犯他人合法权益的情形。如您从事了禁止行为或将服务、输入内容、输出内容用于禁止用途，您应当独立承担全部后果和责任，如给我们造成损失的，您应当赔偿。\",\"如发现您的输入内容或输出内容存在违法违规、违反本须知或违反服务协议的情形时，我们有权视情况采取删除、屏蔽、拒绝输出相关内容等措施，并有权对您的账号采取冻结、封禁或关闭等处置措施。如您发现输入内容或输出内容存在前述情形的，应当立即采取删除、更换内容等适当措施，避免相关内容的生成或传播，并及时向我们反馈相关情况。\",\"您知悉、理解并认可，为遵守相关法律法规的规定以及为明确输出内容的权利归属或使用限制，我们有权在输出内容中添加标识、水印，且在您浏览、导出、下载输出内容时有权再次以提示语等显著形式告知您如何使用上述输出内容及其限制。除非另有约定，您不得篡改或移除我们在输出内容中添加的标识、水印。同时，您使用输出内容时应当根据实际使用场景进行必要的标识和提示，说明其为AI生成内容，避免造成误导或混淆，如因您未进行必要的标识和提示而导致的任何后果和责任由您独立承担。\",\"由于输出内容均产生于技术模型，尽管我们已经努力在改善模型算法，但是由于技术发展的局限性，仍不能保证服务或输出内容的适用性、准确性、可靠性、完整性。您知悉、理解并认可，本功能仅为辅助您使用海螺AI的内容生成服务而设置，我们不对本功能的适用性、准确性、可靠性、完整性作出任何保证或承担任何责任，您亦不会因此向我们提出任何主张。\"]},{\"title\":\"- 服务完善和意见反馈\",\"list\":[\"我们将不断完善海螺AI和本功能，并适时修订、更新本须知及服务协议。如本功能或本须知有任何变更，我们将在功能相关界面告知您。如您不同意相关变更，请停止使用本功能。您继续使用本功能的，即视为已同意、接受修改后的版本，并应当予以遵守。\",\"欢迎您在使用服务的过程中向我们反馈您的意见和建议，帮助我们优化和完善服务。同时，我们高度重视保护知识产权和人格权等合法权益。如果您认为服务或者他人对服务的使用存在侵犯您合法权益的情形，请通过feedback@hailuoai.com与我们联系，并提供相应的合法权益证明资料和侵权内容凭证等，我们将第一时间进行核实、处理，对违规内容采取删除、屏蔽等必要措施。\"]}]}"])</script><script>self.__next_f.push([1,"35:T9c9,"])</script><script>self.__next_f.push([1,"我们提供五种会员套餐：基础、标准、大师、至臻、尊享，以及贝壳按需购买，满足不同创作需求。付费套餐每月可获得的贝壳数量如下：\n \n1. 基础会员：\n• 价格：105元/月，限时优惠价55元，促销期结束后将恢复为105元\n• 每月获得1000贝壳，可生成约40个6秒768P视频/20个10秒768P视频/12个6秒1080P视频\n• 支持生成6秒1080P高清视频\n• 支持下载无水印的图片和视频内容\n• 每次最多可提交5个任务，单线程排队执行\n \n2. 标准会员：\n• 价格：385元/月，限时优惠价196元，促销期结束后将恢复为385元\n• 每月获得4500贝壳，可生成约180个6秒768P视频/90个10秒768P视频/56个6秒1080P视频\n• 支持生成10秒的1080P高清视频\n• 支持下载无水印内容\n• 每次最多可提交5个任务，2个任务可同时并行处理，提升生成效率\n \n3. 大师会员：\n• 价格：799元/月，限时优惠价463元，促销期结束后将恢复为799元\n• 每月获得10000贝壳，可生成400个6秒768P视频/200个10秒768P视频/125个6秒1080P视频\n• 支持生成10秒1080P高清视频\n• 支持下载无水印内容\n• 每次最多可提交5个任务，2个任务可同时并行处理，提升生成效率\n \n4. 至臻会员：\n• 价格：899元/月\n• 每月获得12000贝壳，可用于Hailuo 02模型生成约480个6秒768P视频/240个10秒768P视频/150个6秒1080P视频\n• 解锁Hailuo 01模型无限制生成权限（不消耗贝壳）\n• 支持生成10秒1080P高清视频\n• 每次最多可提交5个任务，支持双任务并发生成\n\n5. 尊享会员（最优惠套餐）：\n价格：1399 元/月\n• 每月获得20000贝壳，可用于使用Hailuo 01和02模型以及Agent，可生成约900个6秒768P视频/400个10秒768P视频/250个6秒1080P视频\n• 无限使用Hailuo 01/02模型生成视频\n• 支持生成10秒1080P高清视频\n• 每次最多可提交5个任务，支持双任务并发生成\n\n \n6. 如果您需要更多贝壳，您随时可以选择购买贝壳：\n• 购买的贝壳有效期为1年，至订购之日后第二个日历年的12月31日\n• 如果您不是付费用户，仅购买贝壳并不会享有会员权益（包括快速通道和无水印等）\n• 我们目前有限时优惠，购买贝壳多得43%。例如，您购买350个贝壳，实际上可以获得350+350×43%=500个贝壳。本优惠仅限直接购买贝壳的情况，不对前述付费套餐生效。"])</script><script>self.__next_f.push([1,"32:[\"$\",\"$L33\",null,{\"formats\":{\"dateTime\":{\"short\":{\"day\":\"numeric\",\"month\":\"short\",\"year\":\"numeric\"},\"long\":{\"day\":\"numeric\",\"month\":\"long\",\"year\":\"numeric\",\"hour\":\"numeric\",\"minute\":\"numeric\"}}},\"locale\":\"zh-Hans\",\"messages\":{\"02_upgrade_modal_confirm\":\"立即升级\",\"02_upgrade_modal_console\":\"保留原有方案\",\"3_biggest_sale_tips\":\"🔥🔥史上最大折扣来袭！！尊享会员首次折扣，全年仅此一次\",\"3_biggest_sale_tips2\":\"史上最大折扣！畅享无限生成！\",\"3_biggest_sale_tips3\":\"🔥🔥史上最大折扣！\",\"Account_deleted\":\"账号已注销\",\"Agent_price_slash_pop_cont\":\"亲爱的创作者们，我们为Agent视频创作带来了两项突破性升级：\\n✅ \u003cstrong\u003e价格大幅下调\u003c/strong\u003e：Agent视频生成费用全面降价，性价比飙升\\n✅ \u003cstrong\u003e效率翻倍\u003c/strong\u003e：支持双Agent任务并发，让你的创作速度更快\\n现在体验，立享双倍效率+超值低价！\",\"Agent_price_slash_pop_got\":\"知道了\",\"Agent_price_slash_pop_title\":\"模板视频重磅福利！\",\"Agent_price_slash_pop_try\":\"立即体验\",\"All_media\":\"全部作品\",\"B_roll_insert\":\"插入\",\"Detailed_view\":\"详细视图\",\"FAQ_10_A\":\"\u003cstrong\u003e完全不会！\u003c/strong\u003e 好消息是，会员权益与所有新手福利是可以\u003cstrong\u003e叠加使用\u003c/strong\u003e的。您在保留赠送声贝的同时，还能立刻享受更快的生成速度和商用授权等高级会员权益。\",\"FAQ_10_Q\":\"订阅会员会影响我的新手礼包吗？\",\"FAQ_11_A\":\"用户每日拥有 \u003cstrong\u003e5 次 \u003c/strong\u003e音色预览音频的免费试听机会，此机会为 \u003cstrong\u003e声音克隆、音色设计 \u003c/strong\u003e页面通用额度，在任一页面试听均会消耗该次数。当当日免费试听机会用尽后，继续生成试听音频将按规则消耗声贝。\",\"FAQ_11_Q\":\"声音克隆和音色设计的试听预览次数是如何统计的？\",\"FAQ_1_A\":\"您可以随时取消定期订阅，但如果您在订阅期结束前取消，我们将不会退还已向我们支付的任何订阅费用。\",\"FAQ_1_Q\":\"退款政策是什么？\",\"FAQ_2_A\":\"文本和积分的转换关系取决于你使用的语言。通常来说，一个英文字母等于一个积分，而一个中文汉字或日文字符等于两个积分。你可以在输入框的左下角查看单个字符和积分的转换关系。\",\"FAQ_2_Q\":\"文本和积分的转换关系是什么？\",\"FAQ_3_A\":\"\u003cstrong\u003e个人用途\u003c/strong\u003e（如社交媒体发布或非营利性的会议）您可以免费使用MiniMax语音生成的音频，只需添加我们的\u003cstrong\u003e标识\u003c/strong\u003e或\u003cstrong\u003e标注\u003c/strong\u003e音频来源。如需将音频用于\u003cstrong\u003e商业用途\u003c/strong\u003e（如创收内容或商业项目），请订阅我们的\u003cstrong\u003e标准版会员及以上\u003c/strong\u003e。\",\"FAQ_3_Q\":\"能否将生成的音频用于我的项目或发布在社交平台上？\",\"FAQ_4_A\":\"输入框中的字符上限取决于您的\u003cstrong\u003e剩余声贝数\u003c/strong\u003e，系统会根据模型价格将声贝数转换为可用字符数。若转换后的字符数超过模型本身的限制（HD模式5000字符，Turbo模式10000字符），则会以模型最大限制为准。长文模式单次合成支持最长支持20w字符（任意模型）。\",\"FAQ_4_Q\":\"每次能将多少文字转成音频？\",\"FAQ_5_A\":\"为了保证\u003cstrong\u003e模型最佳性能\u003c/strong\u003e，我们设定了字符限制（HD模式5,000字符，Turbo模式10,000字符）。\",\"FAQ_5_Q\":\"音频生成为什么有字数限制？\",\"FAQ_6_A\":\"HD 是效果最佳的高保真模型，适合更专业的音频生成场景；Turbo 性价比提升了40%，且支持更长文本，非常适合快速打样或极速生成。\",\"FAQ_6_Q\":\"如何选择 HD或Turbo 模型？\",\"FAQ_7_A\":\"当您从旧套餐升级到新套餐的时候，会把旧套餐当前的声贝余量进行折价，您在升级的时候付差价即可\",\"FAQ_7_Q\":\"如果我升级计划（例如从“创作版”升级到“专业版”），会有费用抵扣或减免吗？\",\"FAQ_8_A\":\"\u003cstrong\u003e不会\u003c/strong\u003e。 只有成功完成的生成任务才会计费。任何由于系统原因未能生成的音频都不会消耗您的任何额度。\",\"FAQ_8_Q\":\"如果音频生成失败，会扣除我的声贝吗？\",\"FAQ_9_A\":\"我们提供非常灵活的\u003cstrong\u003e按需购买\u003c/strong\u003e声贝的选项。您无需在多个会员计划之间纠结，可以根据需要随时购买声贝补充包。这类声贝的有效期为2个月。在2026年2月12日前通过充值获取的额度，有效期仍维持2年，系统将自动优先消耗临期额度。\",\"FAQ_9_Q\":\"你们提供无需订阅会员的充值方案吗？\",\"FAQ_title\":\"常见问题\",\"First_3_mo_discount_enterence\":\"首购优惠\",\"First_3_mo_discount_month\":\"后续每月支付 1399\",\"First_3_mo_discount_quarter\":\"后续每季支付 4199\",\"First_3_mo_discount_tag\":\"首购优惠\",\"First_3_mo_discount_title\":\"前三个月享优惠\",\"First_3_mo_discount_year_false\":\"后续每年支付 16799\",\"First_3_mo_discount_year_ture\":\"第一年支付 14279\",\"H5_copy_message\":\"链接已复制！\",\"H5_link\":\"https://www.minimax.io/audio\",\"H5_logo1\":\"MiniMax\",\"H5_logo2\":\"语音\",\"H5_redirect_message\":\"在电脑上打开以获得最佳体验\",\"H5_subtitle\":\"MiniMax AI，为您打造个性化语音内容，可自由调节语言种类、音色特点和情感表达。\",\"H5_view_tip\":\"请使用电脑访问该页面以获得最佳体验。\",\"HD_model_duration_tip\":\"音频生成时长基于高保真HD模型预估，切换至Turbo模型，总生成时长约增加 1.6 倍。\",\"HP_AB_audio_title\":\"有声书示例\",\"HP_AB_window_fileError_toast\":\"上传的文件必须小于50MB，少于10000个字符。请添加新的文件。\",\"HP_AB_window_or\":\"或者\",\"HP_AB_window_subtitle1\":\"上传文档\",\"HP_AB_window_subtitle2\":\"导入URL\",\"HP_AB_window_subtitle3\":\"语音\",\"HP_AB_window_subtitle4\":\"语音设置\",\"HP_AB_window_title\":\"创建有声书\",\"HP_AB_window_uploadbox_subtitle\":\".pdf, .txt, .html, .docx；最多50MB。\",\"HP_AB_window_uploadbox_title\":\"点击或拖动上传到这里。\",\"HP_AB_window_uploadbox_title_h5_0\":\"从相册选取上传\",\"HP_AB_window_uploadbox_title_h5_1\":\"浏览本地文件上传\",\"HP_AB_window_urlError_toast\":\"URL无效，请添加一个新的URL\",\"HP_AB_window_url_placeholder\":\"在此处插入您的URL\",\"HP_EL_audio_title\":\"教育数字人示例\",\"HP_EL_window_subtitle1\":\"文本\",\"HP_EL_window_subtitle2\":\"语言\",\"HP_EL_window_subtitle3\":\"声音\",\"HP_EL_window_subtitle4\":\"声音设置\",\"HP_EL_window_text_placeholder\":\"输入您的课程材料以生成生动的教育音频！\",\"HP_EL_window_title\":\"助力您的在线学习\",\"HP_SS_audio_title\":\"说书\",\"HP_SS_window_text_placeholder\":\"在此输入您的说书内容、古代传奇或民间故事，我们将为您的文字赋予动人声音，为听众带来沉浸式说书体验!\",\"HP_VO_audio_title\":\"配音示例\",\"HP_VO_window_subtitle1\":\"文本\",\"HP_VO_window_subtitle2\":\"语言\",\"HP_VO_window_subtitle3\":\"声音\",\"HP_VO_window_subtitle4\":\"声音设置\",\"HP_VO_window_text_placeholder\":\"输入您的广告、视频脚本或任何您想听到的文字！比如：'厌倦了传统的剃须工具？介绍UltraEdge剃须刀...；\",\"HP_VO_window_title\":\"创建配音\",\"HP_XWBB_audio_title\":\"新闻播报\",\"HP_YSPY_audio_title\":\"影视配音\",\"HP_YSPY_window_text_placeholder\":\"输入您想要配音的电影台词、动画角色对白或影视片段，让专业配音为您的文字增添灵魂！\",\"HP_banner_btn\":\"立即尝试\",\"HP_banner_subtitle\":\"用一句话表达你的独特声音\",\"HP_banner_title\":\"让文字栩栩如“声”\",\"HP_cn_VI_subtitle\":\"去除音频中的环境与背景噪声，提取并增强原始人声的清晰度与纯净度\",\"HP_cn_isolated_resluts\":\"纯净人声\",\"HP_service_AB_subtitle\":\"用我们多元化的声音库，让书籍鲜活起来\",\"HP_service_AB_title\":\"有声书\",\"HP_service_EL_subtitle\":\"将学习材料转换为清晰且吸引人的音频。\",\"HP_service_EL_title\":\"在线学习\",\"HP_service_VO_subtitle\":\"使用我们多功能的语音修饰器创建配音。\",\"HP_service_VO_title\":\"配音\",\"HP_service_title\":\"TTS服务\",\"HP_tools_btn\":\"立刻尝试\",\"HP_tools_clone_result\":\"纯净人声\",\"HP_tools_original_audio\":\"原始音频\",\"HP_tools_text_subtitle\":\"去除音频中的环境与背景噪声，提取并增强原始人声的清晰度与纯净度\",\"HP_tools_text_title\":\"人声提取\",\"HP_tools_title\":\"语音工具台\",\"HP_voices_explore_btn\":\"发现更多\",\"HP_voices_title\":\"音色推荐\",\"HP_window_btn\":\"创建\",\"HP_window_defult\":\"(默认)\",\"HP_window_text_reference\":\"文案\",\"Hailuo_UID\":\"Hailuo UID\",\"Image\":\"Image\",\"Image_generation_face_reference\":\"人脸参考\",\"Long_maximum_task_notification\":\"最多同时进行10个生成任务\",\"Music_model_tip\":\"Music 2.5模型专注细节精控，编曲、人声、结构、声设四大核心能力大幅升级。\",\"My_voice_empty\":\"我的音色目前为空\",\"New_subscription_max_0_credit_pop\":\"贝壳被消耗光了。你可以通过低速通道，继续使用Hailuo01/02模型无限生成视频。\",\"New_subscription_max_low_speed_cell_1\":\"低速生成中，约等待%s分钟\",\"New_subscription_max_low_speed_cell_2\":\"充值贝壳以使用快速通道\",\"New_subscription_max_low_speed_tips\":\"已进入低速模式。充值即恢复快速通道\",\"New_subscription_max_low_speed_tips_button\":\"充值\",\"New_subscription_max_plan_cont\":\"- 每月 30000 会员贝壳\\n- 无限使用Hailuo 01/02模型生成视频（贝壳数不足时会进入低速模式）\\n- 1080p视频生成\\n- 10 秒视频生成\\n- 单次最多5个生成任务\\n- 同一时间2个任务进行\\n- 图片、视频去水印\",\"New_subscription_max_pop_cont\":\"应广大用户的热切期待，我们正式推出全新【尊享会员】套餐，为您解锁海螺01和02无限畅用特权。\\n订阅【尊享会员】，您将获得：\\n✅ 20,000贝壳：可用于使用快速通道生成海螺01，02视频及模板视频\\n✅ 无限模式：贝壳用尽后，仍可通过低速通道无限畅用海螺01和02\\n即刻升级尊享会员，解锁视频创作的终极体验！\",\"New_subscription_max_pop_got\":\"我知道了\",\"New_subscription_max_pop_title\":\"全新【尊享会员】套餐上线\",\"New_subscription_max_pop_view\":\"立即升级→\",\"New_subscription_unlimited_0_credit_pop\":\"贝壳被消耗光了。你可以继续使用Hailuo01模型无限次生成视频。\",\"No_content\":\"暂无文件\",\"Plan_subtitle\":\"选择最适合您的套餐，或按需充值声贝。\",\"Plan_title\":\"选择您的订阅方案\",\"Quantity_file\":\"个文件\",\"Ratio\":\"比例\",\"Refresh\":\"刷新\",\"Reset_modifier_btn\":\"清空\",\"Settings\":\"设置\",\"Simple_view\":\"精简视图\",\"Subscribe_for_credits\":\"订阅会员以获取更多贝壳\",\"TTS_Exceptional_Problem\":\"系统异常，请稍后再试。\",\"TTS_accent_afc\":\"非洲\",\"TTS_accent_arb\":\"阿拉伯\",\"TTS_accent_au\":\"澳大利亚\",\"TTS_accent_aus\":\"澳大利亚\",\"TTS_accent_can\":\"加拿大\",\"TTS_accent_cari\":\"加勒比地区\",\"TTS_accent_ch\":\"中国\",\"TTS_accent_en\":\"英国\",\"TTS_accent_enad\":\"英格兰（非洲裔）\",\"TTS_accent_fr\":\"法国\",\"TTS_accent_india\":\"印度\",\"TTS_accent_ire\":\"爱尔兰\",\"TTS_accent_jp\":\"日本\",\"TTS_accent_latin\":\"拉丁美洲\",\"TTS_accent_mid\":\"美国（中部地区）\",\"TTS_accent_nz\":\"新西兰\",\"TTS_accent_sco\":\"苏格兰\",\"TTS_accent_sp\":\"西班牙\",\"TTS_accent_us\":\"美国（标准）\",\"TTS_accent_usaa\":\"美国（非裔)\",\"TTS_clear_textbox\":\"清空文本\",\"TTS_credit_count\":\"字符\",\"TTS_delete_window_cancel\":\"取消\",\"TTS_delete_window_confirm\":\"确认\",\"TTS_delete_window_subtitle\":\"此操作无法撤销\",\"TTS_delete_window_title\":\"确认删除这条语音吗？\",\"TTS_download_btn\":\"下载\",\"TTS_exceed\":\"内容超过了{{character}}字符的限制。\",\"TTS_generate_btn\":\"生成音频\",\"TTS_generating_btn\":\"生成中\",\"TTS_history_detail_VM_settings\":\"音色效果器参数\",\"TTS_history_detail_auditorium_echo\":\"礼堂广播\",\"TTS_history_detail_back\":\"返回生成历史\",\"TTS_history_detail_credit\":\"声贝消耗\",\"TTS_history_detail_restore_setting_1\":\"音色已复用\",\"TTS_history_detail_restore_settings\":\"复用音色设置\",\"TTS_history_detail_restore_text\":\"复用文案\",\"TTS_history_detail_restore_text_1\":\"文案已复用\",\"TTS_history_detail_setting_deepen_lighten\":\"低沉/明亮\",\"TTS_history_detail_setting_emotion\":\"情绪\",\"TTS_history_detail_setting_lofi_telephone\":\"电话失真\",\"TTS_history_detail_setting_model\":\"模型\",\"TTS_history_detail_setting_nasal_crisp\":\"磁性/清脆\",\"TTS_history_detail_setting_pitch\":\"语调\",\"TTS_history_detail_setting_robotic\":\"电音\",\"TTS_history_detail_setting_spacious_echo\":\"空旷回声\",\"TTS_history_detail_setting_speed\":\"语速\",\"TTS_history_detail_setting_stronger_softer\":\"力量感/柔和\",\"TTS_history_detail_setting_volume\":\"音量\",\"TTS_history_empty\":\"无生成历史\",\"TTS_history_hover_delete\":\"删除\",\"TTS_history_hover_details\":\"音频详情\",\"TTS_history_restore\":\"恢复\",\"TTS_history_title\":\"生成历史\",\"TTS_language_dut\":\"荷兰语\",\"TTS_language_en\":\"英语\",\"TTS_language_fr\":\"法语\",\"TTS_language_gm\":\"德语\",\"TTS_language_id\":\"印度尼西亚语\",\"TTS_language_ita\":\"意大利\",\"TTS_language_jp\":\"日语\",\"TTS_language_kr\":\"韩语\",\"TTS_language_pt\":\"葡萄牙语\",\"TTS_language_rus\":\"俄罗斯语\",\"TTS_language_sp\":\"西班牙语\",\"TTS_language_tr\":\"土耳其语\",\"TTS_language_ukr\":\"乌克兰语\",\"TTS_language_vie\":\"越南语\",\"TTS_language_yueyu\":\"粤语\",\"TTS_language_zh\":\"中文-普通话\",\"TTS_nofreetrial_window_text\":\"订阅会员，解锁声音调试台的完整功能\",\"TTS_nofreetrial_window_title\":\"不好意思，您已用完了试用机会\",\"TTS_regenerate_btn\":\"重新生成音频\",\"TTS_reset_language\":\"清空选择\",\"TTS_safe_denied\":\"换个内容试试吧\",\"TTS_settings_Emotion\":\"输出情绪\",\"TTS_settings_Pitch\":\"声调\",\"TTS_settings_Speed\":\"语速\",\"TTS_settings_VM\":\"音色效果调节\",\"TTS_settings_auto\":\"自动\",\"TTS_settings_language\":\"语言\",\"TTS_settings_title\":\"调试台\",\"TTS_settings_voice\":\"音色\",\"TTS_subtitle\":\"MiniMax语音，为您打造个性化语音内容，可自由调节语言种类、音色特点和情感表达。\",\"TTS_switch_voice_btn\":\"切换音色\",\"TTS_textbox\":\"在此处开始输入文字，生成您的个性化音频。\",\"TTS_title\":\"文字转语音\",\"TTS_voice_age_option1\":\"青年\",\"TTS_voice_age_option2\":\"成年\",\"TTS_voice_age_option3\":\"中年\",\"TTS_voice_age_option4\":\"老年\",\"TTS_voice_change_btn\":\"切换音色\",\"TTS_voice_gender_option1\":\"男性\",\"TTS_voice_gender_option2\":\"女性\",\"TTS_voice_search_placeholder\":\"搜索语音库\",\"TTS_voice_select_accent\":\"口音\",\"TTS_voice_select_age\":\"年龄\",\"TTS_voice_select_box\":\"音色选择\",\"TTS_voice_select_gender\":\"性别\",\"TTS_voice_select_library\":\"音色库\",\"TTS_voice_select_myvoice\":\"我的音色\",\"TTS_voice_select_no_option\":\"无对应选项\",\"TTS_voice_select_scenario\":\"场景\",\"TTS_voice_select_selected\":\"已选\",\"TTS_voice_select_use\":\"选择\",\"Tab_VI\":\"人声提取\",\"Type\":\"类型\",\"VC_btn_title\":\"创建你的语音克隆\",\"VC_claim\":\"我已阅读并同意{{termsOfServiceLink}}；我确认对所上传的声音样本具有充分、合法、必要的权利或授权，并同意将其用于使用声音克隆功能；我承诺不将本功能用于违法违规的目的或用途。\",\"VC_convert\":\"一键克隆\",\"VC_converting\":\"克隆中\",\"VC_exit_window_subtitle\":\"如果现在离开，您当前的编辑都不会被保存\",\"VC_exit_window_title\":\"确定离开这个页面吗？\",\"VC_file_exceed\":\"文件大小不能超过50MB\",\"VC_file_length_toast1\":\"音频时长需要保持在1-300s之间\",\"VC_file_length_toast2\":\"音频时长需要再10-300s之间\",\"VC_import\":\"步骤一：导入语音\",\"VC_isolater\":\"从音频样本中去除背景噪音（可选，可能会影响声音细节）。\",\"VC_language\":\"步骤三：语言选择\",\"VC_language_tip\":\"选择与原音频相同的语言以获得最佳的语音克隆效果。\",\"VC_length_exceed\":\"音频时长需要再10-300s之间\",\"VC_length_safe\":\"文件有问题，请添加新文件。\",\"VC_name\":\"步骤二：命名你的语音\",\"VC_name_tip\":\"为你的克隆语音命名\",\"VC_no_slots_toast\":\"您已经用完了音色槽位额度，立即升级您的套餐以定制更多音色。\",\"VC_record\":\"录制音频\",\"VC_recording_length_toast\":\"开始录音即表示您已取得声音授权\",\"VC_requirement\":\"请在安静的环境中上传干净的语音录音。混响、多位说话者、背景噪音等都会影响语音克隆的质量。\\\\n 你可以使用噪声分离功能来减少音频噪声，但这也可能影响语音的细节。因此，建议在选择克隆材料时挑选质量最好的片段。\",\"VC_reset\":\"重置\",\"VC_reset_window_subtitle\":\"若您选择重置，所有的内容都不会被保存\",\"VC_reset_window_title\":\"您确定吗？\",\"VC_safe_denied\":\"该音色不可用\",\"VC_safe_review\":\"审核中\",\"VC_sample_cnt\":\"录音样本\",\"VC_slot_tip\":\"剩余音色槽位：\",\"VC_subtitle\":\"朗读一段文字，即可克隆你的专属声音\",\"VC_title\":\"声音克隆\",\"VC_upload\":\"添加或拖放文件\",\"VC_upload_10mb\":\"每个最大50MB\",\"VI_cancel_btn\":\"取消\",\"VI_confirm_btn\":\"确认\",\"VI_drag_upload_message\":\"松开鼠标即可上传文件\",\"VI_dropbox_message\":\"添加或拖放音频或视频文件，文件大小不超过500MB，时长不超过300秒\",\"VI_file_size_exceed_error\":\"添加的文件大小不可超过500MB，时长不超过300秒。您的音频文件不符合要求，请重新上传。\",\"VI_isolate_btn\":\"提取人声\",\"VI_isolate_hover\":\"人声提取服务将按每分钟 1000 声贝进行声贝消耗\",\"VI_isolate_success_tag\":\"提取完成\",\"VI_isolated_audio_title\":\"（上传文件名-isolated.文件格式）\",\"VI_leave_popup_subtitle\":\"离开页面后，我们将不会保存当前任务\",\"VI_leave_popup_title\":\"确认要离开该页面吗？\",\"VI_loading_message\":\"消除背景音，提取人声中...\",\"VI_record_btn\":\"开始录音\",\"VI_record_time_limit_message\":\"最长可录制60秒\",\"VI_sub_title\":\"去除音频中的环境与背景噪声，提取并增强原始人声的清晰度与纯净度\",\"VI_timeout_message\":\"生成时间过长，请重试。\",\"VI_title\":\"人声提取\",\"VI_upload_audio_title\":\"(上传文件名)\",\"VI_upload_btn\":\"上传音频\",\"Veo_3_1_app_dec\":\"High-fidelity 8s videos with realism and native audio\",\"Veo_3_1_dec\":\"音画同步，高保真，精准控制\",\"Veo_3_1_fast_app_dec\":\"Faster, high-fidelity 8s videos with realism and native audio\",\"Veo_3_1_fast_dec\":\"音画同步，更高速，更高性价比\",\"Veo_3__fast_dec\":\"生成具有内置高保真音频的超真实8秒视频，分辨率为720p/1080p——速度更快且更具性价比\",\"Veo_3_dec\":\"生成具有内置高保真音频的超真实8秒视频，分辨率为720p/1080p\",\"Video\":\"Video\",\"View_all_subscription\":\"查看所有订阅\",\"Volume\":\"音量\",\"about_hailuo_hailuo_ai\":\"海螺AI\",\"about_hailuo_model_name_record_number\":\"模型名称：%s    备案号：%s\",\"about_hailuo_privacy_policy\":\"隐私政策\",\"about_hailuo_version\":\"版本v%s\",\"about_hailuo_video_service_agreement\":\"海螺AI服务协议\",\"about_hailuoai\":\"关于海螺 AI\",\"about_minimax\":\"关于 MiniMax\",\"account\":\"Account\",\"account_balance\":\"余额\",\"account_details\":\"账号信息\",\"account_page\":\"昵称\",\"account_preferences\":\"用户偏好\",\"account_recharge\":\"充值\",\"account_settings_avatar_nickname\":\"头像昵称\",\"account_settings_phone_number\":\"手机号\",\"account_settings_unlinked\":\"未绑定\",\"account_settings_wechat_account\":\"微信账号\",\"active_membership_top_bar\":\"开通会员立享加速权益\",\"active_membership_top_bar_web\":\"海量积分，快速生成，无水印下载！\",\"active_membership_top_button\":\"即刻开通\",\"active_subscription_warning\":\"当前账号还存在生效中的订阅，请取消订阅后再进行操作\",\"add_photo_confirm\":\"将指定内容添加至...\",\"add_to_chat_btn_text\":\"添加到对话\",\"affiliate_earn_status_1\":\"待结算\",\"affiliate_earn_status_2\":\"可提现\",\"affiliate_earn_status_3\":\"已退款\",\"affiliate_earn_status_4\":\"已退款\",\"affiliate_earnings_empty_text\":\"你暂时还没有收益详情～\",\"affiliate_empty_text\":\"你暂时还没有邀请记录～\",\"affiliate_faq\":\"常见问题\",\"affiliate_faq_answer_1\":\"目前，我们的联盟计划采用定向邀请制。我们仅向精选的合格用户发送邀请。请留意您的通知，期待收到我们的邀请！\",\"affiliate_faq_answer_10\":\"当您推荐的用户中出现大量退款时，我们会冻结部分收益作为风险防控措施。冻结机制如下：\\n\\n- 退款率20%至\u003c30%：冻结您的可提现收益 + 20%的在途收益\\n- 退款率30%至\u003c50%：冻结您的可提现收益 + 50%的在途收益\\n- 退款率≥50%：冻结全部可提现和在途收益\\n\\n冻结触发后，您将进入30天观察期。如果观察期内日均退款率保持在10%以下，我们将每7天解冻25%的收益。如果退款率超过10%，观察期计时器将重置。\",\"affiliate_faq_answer_11\":\"当您推荐的用户出现退款或拒付情况时，我们会从您的佣金中扣除相应金额。如果您的可提现余额不足以覆盖这些扣除额，您的收益将显示为负数，直到未来的佣金弥补这一差额。\",\"affiliate_faq_answer_12\":\"我们的联盟计划目前仅专注于产品销售。我们不提供多层级的佣金系统，因此您无法从您推荐的其他联盟会员的销售中获得佣金。不过，请持续关注我们未来可能推出的计划更新！\",\"affiliate_faq_answer_13\":\"我们禁止使用垃圾邮件、误导性广告以及任何违反我们条款和条件的方法。任何可能损害海螺AI声誉的推广活动也严格禁止。我们希望我们的联盟会员始终保持道德营销实践。\",\"affiliate_faq_answer_14\":\"不可以，创建可能被误认为是海螺AI官方网站或账号的网站或社交媒体资料是严格禁止的。您的推广材料应清楚表明您是联盟合作伙伴，而非海螺AI的官方代表。\",\"affiliate_faq_answer_15\":\"违反我们的推广指南可能导致您的联盟账户被暂停或终止。此外，我们保留扣留通过禁止推广方式获得的任何佣金的权利。我们严肃对待联盟计划的诚信问题，以维护与客户的信任关系。\",\"affiliate_faq_answer_2\":\"个人、博主、社交媒体influencer、网站所有者和企业均可申请，前提是满足以下条件：\\n  - 遵守我们平台的服务条款和推广政策\\n  - 不推广非法、侵权或成人内容\\n  - 遵守您所在国家和推广地区的法律法规\",\"affiliate_faq_answer_3\":\"您的收入潜力没有上限！对于您推荐给我们Standard、Pro和Unlimited计划的任何付费用户，您将获得他们首月订阅费用的10%作为佣金。推广越多，收益越高。\\n\\n举例：如果您推荐了10位Pro月度用户和20位Unlimited年度用户，您将获得：\\n(10×$34.99 + 20×$1139.88) × 95% × 10% = $2,199\\n\\n- $34.99为Pro月度计划价格，$1139.88为Unlimited年度计划价格\\n- 95%代表受邀用户在享受5%折扣后的实际支付金额\\n- 10%是您的佣金比例\",\"affiliate_faq_answer_4\":\"我们的佣金结构旨在让联盟会员和新客户都受益：\\n- 您获得通过您的推荐链接产生的每笔订阅的10%佣金\\n- 通过您的链接注册的新用户在首次订购时享受5%的折扣\\n- 佣金基于受邀客户支付的折扣后金额计算\",\"affiliate_faq_answer_5\":\"您可以在联盟计划页面实时跟踪您的收益。佣金在受邀客户付款30天后才可提现。例如，如果客户在3月1日购买订阅，该笔佣金将记为在途收益，并于4月1日变为可提现状态。\\n\\n对于年度订阅，我们分期发放佣金。在前6个月，您每月将获得总佣金的1/12，第7个月将一次性获得剩余的6/12佣金。例如，如果您从年度订阅中获得$120的佣金，前六个月您每月将收到$10，第七个月将一次性收到$60。\",\"affiliate_faq_answer_6\":\"您可以邀请以下用户：\\n- 尚未订阅我们任何付费计划的用户\\n- 尚未被其他联盟会员推荐的用户\",\"affiliate_faq_answer_7\":\"您的推荐链接Cookie有效期为7天。这意味着，如果用户点击您的链接并在7天内完成购买，您将获得相应的销售佣金。\",\"affiliate_faq_answer_8\":\"不可以，联盟计划会员不能从自己的购买中获得佣金。联盟计划旨在奖励您带来新客户。\",\"affiliate_faq_answer_9\":\"如果您推荐的客户申请退款，相关佣金将不予支付或从您未来的收益中扣除。如果您的推荐用户出现较高的退款率，我们可能会暂时冻结部分收益，直至退款率恢复正常。对于疑似欺诈活动的情况，我们保留拒绝付款或清除收益的权利。\",\"affiliate_faq_question_1\":\"如何加入联盟计划？\",\"affiliate_faq_question_10\":\"什么是冻结收益？如何解冻？\",\"affiliate_faq_question_11\":\"为什么我的可提现收益显示为负数？\",\"affiliate_faq_question_12\":\"我可以从推荐加入的其他联盟会员的销售中获得佣金吗？\",\"affiliate_faq_question_13\":\"联盟计划中禁止哪些推广方式？\",\"affiliate_faq_question_14\":\"我可以创建可能被误认为是海螺AI官方网站或社交媒体的网站或账号来进行推广吗？\",\"affiliate_faq_question_15\":\"违反推广指南会有什么后果？\",\"affiliate_faq_question_2\":\"谁有资格加入联盟计划？\",\"affiliate_faq_question_3\":\"作为联盟会员，我能赚取多少佣金？\",\"affiliate_faq_question_4\":\"佣金结构是如何运作的？\",\"affiliate_faq_question_5\":\"我何时以及如何收到佣金付款？\",\"affiliate_faq_question_6\":\"我可以邀请哪些用户加入计划？\",\"affiliate_faq_question_7\":\"我的推荐链接Cookie的有效期是多久？\",\"affiliate_faq_question_8\":\"我可以使用自己的推荐链接购买并赚取佣金吗？\",\"affiliate_faq_question_9\":\"如果我推荐的客户申请退款，会怎样？\",\"affiliate_invite_status_\":\"邀请已过期\",\"affiliate_invite_status_1\":\"已订阅\",\"affiliate_invite_status_2\":\"尚未订阅\",\"affiliate_invite_status_3\":\"邀请即将过期\",\"affiliate_invite_status_4\":\"已过期\",\"affiliate_program_nav_text\":\"邀请好友\",\"agen_chat_unknown_msg\":\"未知原因导致的任务失败…\",\"agent_audio_25hd_desc\":\"终极相似，超高质量\",\"agent_audio_25turbo_desc\":\"多语言卓越，超级性能\",\"agent_button_chat\":\"对话\",\"agent_button_recreate\":\"重新创建\",\"agent_canva_toolbox_hand_tool\":\"抓手工具\",\"agent_canva_toolbox_select\":\"选择工具\",\"agent_canvas_delete\":\"删除\",\"agent_canvas_download\":\"下载\",\"agent_canvas_duplicate\":\"获取副本\",\"agent_canvas_full_screen\":\"全屏\",\"agent_charge_tip_bottom_1\":\"已经购买积分了吗?\",\"agent_charge_tip_bottom_2\":\"点击继续\",\"agent_charge_tip_msg\":\"您的积分已用完，当前项目还需{chargeCredit}积分，购买后即可继续使用\",\"agent_charge_tip_purchase\":\"购买\",\"agent_charge_tip_subscribe\":\"订阅\",\"agent_charge_tip_title\":\"充值贝壳\",\"agent_chat_Processing\":\"正在进行中...\",\"agent_chat_auto_cut_tips\":\"一键成片模式已启用\",\"agent_chat_back_toast\":\"内容已经自动保存至项目,可到资产查看\",\"agent_chat_click_tip_text_1\":\"已购买积分？\",\"agent_chat_click_tip_text_2\":\"点击这里继续\",\"agent_chat_failed\":\"任务失败，请重试\",\"agent_chat_failed_credit_back\":\"生成失败，扣除的贝壳已退还\",\"agent_chat_finished\":\"任务已完成\",\"agent_chat_generation_failed_toast\":\"生成失败了，辛苦再试一下\",\"agent_chat_hide_chat\":\"隐藏对话\",\"agent_chat_image_generation_complete\":\"图像生成\",\"agent_chat_max_upload_image_toast\":\"最多可以上传{num}张图片\",\"agent_chat_modify_storyboard\":\"请输入要修改的分镜图描述\",\"agent_chat_no_credits_text\":\"你已经没有%s积分了。\",\"agent_chat_open_chat\":\"展开对话\",\"agent_chat_opening_line\":\"有灵感了吗？我们开始创作吧！\",\"agent_chat_prompt_placeholder\":\"告诉我你脑海中的画面\",\"agent_chat_purchase_btn_text\":\"购买\",\"agent_chat_regenerate\":\"重新生成\",\"agent_chat_status_creating\":\"创作中...\",\"agent_chat_status_wait_for_input\":\"等待输入\",\"agent_chat_subscribe_btn_text\":\"订阅\",\"agent_chat_task_fail_msg\":\"任务失败\",\"agent_chat_video_generation_complete\":\"视频生成完成\",\"agent_chat_video_not_supported_toast\":\"暂不支持发送视频消息\",\"agent_content_violate_tips\":\"该内容违反社区规范，请更换提示词重新生成\",\"agent_create_entry_prompt_placeholder\":\"告诉我你脑海中的画面，我来为你创作\",\"agent_credit_detail_text\":\"智能体积分详情\",\"agent_edit_fit_to_window\":\"适应画布\",\"agent_edit_loading\":\"加载中...\",\"agent_edit_paste\":\"粘贴\",\"agent_edit_select_all\":\"全选\",\"agent_edit_smudge_failed_retry\":\"涂抹失败，请重试\",\"agent_edit_zoom_100\":\"放大到100%\",\"agent_edit_zoom_in\":\"放大\",\"agent_edit_zoom_out\":\"缩小\",\"agent_entry_intro_desc_1\":\"只需说出你的想法 — Agent 自动匹配最强模型，让创意瞬间成真\",\"agent_entry_intro_desc_2\":\"在画布上与Agent一起创作，让灵感无限延展、思路清晰可见\",\"agent_entry_intro_desc_3\":\"图片、视频和音频 — 多模态创作，一个 Agent 搞定\",\"agent_entry_intro_title_1\":\"对话即创作\",\"agent_entry_intro_title_2\":\"无限画布\",\"agent_entry_intro_title_3\":\"多模态全能创作\",\"agent_entry_title_colorful\":\"让创作更便捷\",\"agent_entry_title_white\":\"欢迎来到海螺Agent —\",\"agent_feedback_btn\":\"立即反馈\",\"agent_feedback_desc\":\"您的反馈对我们很重要！请花几分钟时间分享您的想法，帮助我们提升您的体验。\",\"agent_feedback_mini_btn\":\"提供反馈\",\"agent_feedback_title\":\"📋 帮助我们改进！\",\"agent_file_upload_failed_retry\":\"上传失败，请重试\",\"agent_final_video\":\"成片\",\"agent_free_trial_banner\":\"📣 Agent即将支持365无限生成权益，享有该权益的用户请优先在创作页使用\",\"agent_free_trial_tag\":\"小提示\",\"agent_home_no_pay_card\":\"由于未付贷款，该项目已暂停。\",\"agent_home_tab_agent\":\"Agent\",\"agent_home_tab_popover\":\"这是智能助手功能介绍。这里是智能助手介绍。智能助手介绍。\",\"agent_home_tab_projects\":\"Project\",\"agent_home_tab_video\":\"视频\",\"agent_image_free_trial_rule\":\"⏰ 限时免费优惠\\n会员12月31号前可以享受免费无限量生成\",\"agent_image_model\":\"模型\",\"agent_input_placeholder\":\"分享您的想法—与智能助手共同创作视频、图片、音乐等内容。\",\"agent_instant_input_placeholder\":\"描述想要的内容，如“1分钟介绍这个商品的短片，风格活泼，有字幕”\",\"agent_landing_advanced_coherence_desc\":\"突破时长限制，生成多镜头连续画面，轻松实现无缝场景切换，呈现沉浸式视觉体验。\",\"agent_landing_advanced_coherence_title\":\"视频场景连贯\",\"agent_landing_advanced_iteration_desc\":\"通过动态图形界面实现即时反馈，所见即所得，边创作边预览，效率与质量同步提升。\",\"agent_landing_advanced_iteration_title\":\"实时迭代与片段生成\",\"agent_landing_advanced_precision_desc\":\"从镜头切换到生成风格，全面调整 AI 参数，精准打造符合需求的每一帧画面。\",\"agent_landing_advanced_precision_title\":\"个性化定制\",\"agent_landing_advanced_title\":\"解锁海螺视频Agent的旗舰级 AI 视频创作能力\",\"agent_landing_advanced_workflow_desc\":\"可视化设计并灵活控制复杂的制作流程，串联多重生成节点，打造真正差异化的视频内容。\",\"agent_landing_advanced_workflow_title\":\"精密工作流编排\",\"agent_landing_ai_video_generation\":\"AI 视频生成\",\"agent_landing_api_subtitle\":\"将我们的AI视频生成功能集成到您的应用程序中\",\"agent_landing_book_demo\":\"预约演示\",\"agent_landing_creation_title_line1\":\"几分钟内创建\",\"agent_landing_creation_title_line2\":\"高效制作高质量视频\",\"agent_landing_desc\":\"探索强大的 AI 智能体，自动化复杂任务，生成创新解决方案，为您的业务提供卓越成果。\",\"agent_landing_explore_all_use_cases\":\"探索所有应用场景\",\"agent_landing_faq_a1\":\"海螺视频 Agent 不止于简单的提示生成或短片模式，它基于可视化工作流支持多镜头、长时长、参数可控的视频创作，满足复杂叙事与专业定制需求。\",\"agent_landing_faq_a2\":\"您可以创作各种类型的视频，包括营销内容、教育培训、叙事短片、产品演示或创意艺术项目，全面掌控视频的长度、风格与叙事结构。\",\"agent_landing_faq_a3\":\"不需要任何专业技术背景。我们直观的拖拽式界面让每个人都能轻松上手，高效完成创作。\",\"agent_landing_faq_a4\":\"传统生成器通常仅限于短片，而海螺视频Agent支持生成更长的多镜头视频，具备流畅的场景衔接与专业级表现力。\",\"agent_landing_faq_q1\":\"视频Agent 与普通 AI 视频生成器有何不同？\",\"agent_landing_faq_q2\":\"我可以用 海螺视频Agent 创建哪些类型的视频？\",\"agent_landing_faq_q3\":\"使用它需要高级技术或编程技能吗？\",\"agent_landing_faq_q4\":\"我生成的视频有长度限制吗？\",\"agent_landing_faq_subtitle\":\"快速了解关于 海螺视频 Agent 的核心问题\",\"agent_landing_faq_title\":\"常见问题\",\"agent_landing_feature_ai_powered_desc\":\"AI 深度学习模型智能理解文本与图片，一键生成专业级视频。\",\"agent_landing_feature_ai_powered_title\":\"AI 智能生成\",\"agent_landing_feature_intuitive_desc\":\"零门槛可视化界面，人人都能轻松完成复杂视频创作。\",\"agent_landing_feature_intuitive_title\":\"零门槛一键成片\",\"agent_landing_feature_realtime_desc\":\"边创作边预览，所见即所得，创意立刻跃然眼前。\",\"agent_landing_feature_realtime_title\":\"实时可视化生成过程\",\"agent_landing_features_description_line1\":\"借助直观的创作流程与强大的 AI 技术\",\"agent_landing_features_description_line2\":\"轻松将灵感转化为引人注目的视频内容\",\"agent_landing_features_title\":\"用 AI 即时打造高质量视频创意\",\"agent_landing_footer_desc\":\"借助我们先进的 AI 驱动平台，将您的创意愿景转化为引人入胜的视频内容。                   加入数千位正在使用海螺视频Agent创作的创作者行列，开启高效创作新体验。\",\"agent_landing_footer_subtitle\":\"AI视频创作助手\",\"agent_landing_footer_title\":\"海螺视频 Agent\",\"agent_landing_hero_description\":\"AI 赋能视频创作，助您高效打造吸睛内容\",\"agent_landing_hero_subtitle\":\"快速生成，高品质呈现\",\"agent_landing_hero_title\":\"海螺视频 Agent\",\"agent_landing_keyword\":\"AI 智能体, 自动化, 人工智能, 智能解决方案, 工作流自动化\",\"agent_landing_learn_more\":\"了解更多\",\"agent_landing_lightning_desc\":\"从构思到最终剪辑，流畅的视频创作，无需等待。\",\"agent_landing_lightning_title\":\"极速生成\",\"agent_landing_pricing_subtitle\":\"选择适合您需求的完美方案\",\"agent_landing_pricing_title\":\"定价\",\"agent_landing_privacy_description\":\"在 海螺视频 Agent，我们致力于保护您的数据和创意资产。您的所有输入、项目文件和生成的视频都经过安全处理。您保留对所创建内容的完全所有权。我们采用强大的安全措施，确保您的信息保持机密，并按照全球隐私标准进行处理。\",\"agent_landing_privacy_title\":\"您的隐私，我们的优先考虑\",\"agent_landing_quick_description\":\"我们直观的平台让每个人都能轻松进行专业视频创作。从概念到完成，用AI的力量让您的想法栩栩如生。\",\"agent_landing_start_creating\":\"开始创作\",\"agent_landing_start_creating_now\":\"立即开始创作\",\"agent_landing_title\":\"AI 智能体 - 智能自动化解决方案\",\"agent_landing_use_case_education_desc\":\"通过将多个概念、视觉示例和解说片段链接成连贯的学习体验，创建全面的解释视频或教程。\",\"agent_landing_use_case_education_title\":\"深度教育内容\",\"agent_landing_use_case_marketing_desc\":\"生成一系列相互关联的宣传视频，从初始预告片到详细的产品展示，全部可根据活动需求实时调整。\",\"agent_landing_use_case_marketing_title\":\"动态营销活动\",\"agent_landing_use_case_storytelling_desc\":\"为短片、游戏概念或艺术项目开发复杂的叙事或可视化复杂场景，具有轻松修改和扩展故事的灵活性。\",\"agent_landing_use_case_storytelling_title\":\"创意叙事与原型设计\",\"agent_landing_use_cases_subtitle\":\"了解 海螺视频 Agent 如何在各个行业和应用中改变创意工作流程。\",\"agent_landing_use_cases_title\":\"启发性应用场景\",\"agent_landing_view_api_docs\":\"查看 API 文档\",\"agent_landing_view_pricing_plans\":\"查看定价方案\",\"agent_landing_watch_demo\":\"观看演示\",\"agent_mobile_copy_success\":\"复制成功！\",\"agent_mobile_description_prefix\":\"目前在移动设备上不可用，请在桌面端打开\",\"agent_mobile_description_suffix\":\"。\",\"agent_mobile_return_home\":\"返回主页\",\"agent_mobile_title\":\"抱歉！\",\"agent_mode_chat_desc\":\"“Painter”模式擅长图像创作，而“Director”模式擅长视频创作。两者都提供相同的功能。\",\"agent_mode_chat_title\":\"选择代理创建模式\",\"agent_mode_desc1\":\"更擅长图像创作\",\"agent_mode_desc2\":\"更擅长视频创作\",\"agent_mode_name_director\":\"导演\",\"agent_mode_name_instant\":\"一键成片\",\"agent_mode_name_instant_tips\":\"Agent自动规划剧本，完成剪辑和配乐等工作，生成一个完整视频\",\"agent_mode_name_painter\":\"画家\",\"agent_mode_title\":\"选择Agent创作模式\",\"agent_model_selection_audio_credits_tip\":\"每 250 字符消耗 1 积分\",\"agent_model_selection_audio_credits_tip_hover\":\"每生成 250 个字符的音频将消耗 1 积分；不足 250 个字符不计积分。\\n示例：230 个字符消耗 0 积分，520 个字符消耗 2 积分。\",\"agent_model_selection_cancel_banned\":\"每个类别必须至少选择一个模型\",\"agent_model_selection_image_credits_tip\":\"每张图片花费1~10积分\",\"agent_model_selection_img_flux_kontext\":\"精准编辑、全面均衡\",\"agent_model_selection_img_kolors\":\"影视画面感、中文语义理解\",\"agent_model_selection_img_nano_banana\":\"精准编辑、多图融合、语境理解\",\"agent_model_selection_img_nano_banana2\":\"最新模型，更强性能，更佳能力\",\"agent_model_selection_img_qwen_image\":\"高保真文本渲染、多种艺术风格、支持图片编辑\",\"agent_model_selection_img_seedance\":\"精确编辑，快速2K–4K生成，更深入的场景理解\",\"agent_model_selection_video_credits_info\":\"2.3和2.0模型：768p 6s=25积分；768p 10s=50积分；1080p 6s=80积分\\n2.3 Fast模型：768p 6s=15积分；768p 10s=30积分；1080p 6s=50积分\\n可以在提示词中指定模型、分辨率和时长\",\"agent_model_selection_video_credits_tip\":\"每个视频生成消耗15–80积分\",\"agent_music_2_desc\":\"灵动人声，精准掌控\",\"agent_notif_less_free_quota_member\":\"今天剩余免费试用次数少于5次\",\"agent_notif_less_free_quota_non_member\":\"剩余免费试用不足5次\",\"agent_notif_no_free_quota_member\":\"今日免费额度已经用完\",\"agent_notif_no_free_quota_non_member\":\"免费额度已用完\",\"agent_pause_